<nodeDefs>

  <!-- Controller Node -->
  <nodeDef id="unifi_controller" nodeType="139" nls="unifi_controller">
    <sts>
      <st id="ST" editor="E_STATUS"/>
    </sts>
    <cmds>
      <sends/>
      <accepts>
        <cmd id="QUERY"/>
        <cmd id="DISCOVER"/>
      </accepts>
    </cmds>
  </nodeDef>

  <!-- Camera Node -->
  <nodeDef id="unifi_camera" nodeType="139" nls="unifi_camera">
    <sts>
      <st id="ST"   editor="E_STATUS"/>  <!-- Connected -->
      <st id="GV1"  editor="E_STATUS"/>  <!-- Motion detected -->
      <st id="GV2"  editor="E_STATUS"/>  <!-- Person detected -->
      <st id="GV3"  editor="E_STATUS"/>  <!-- Vehicle detected -->
      <st id="GV4"  editor="E_STATUS"/>  <!-- Animal detected -->
      <st id="GV5"  editor="E_STATUS"/>  <!-- Package detected -->
    </sts>
    <cmds>
      <sends/>
      <accepts>
        <cmd id="QUERY"/>
      </accepts>
    </cmds>
  </nodeDef>

</nodeDefs>
